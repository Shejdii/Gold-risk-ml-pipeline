import pandas as pd
from pathlib import Path

FEATURE_DIR = Path("data/features")

def test_features_files_exist():
    assert (FEATURE_DIR / "train.csv").exists()
    assert (FEATURE_DIR / "val.csv").exists()
    assert (FEATURE_DIR / "test.csv").exists()

def test_future_regime_is_valid_labels():
    df = pd.read_csv(FEATURE_DIR / "train.csv")
    assert df["future_regime"].isna().sum() == 0
    assert set(df["future_regime"].unique()).issubset({"LOW", "MEDIUM", "HIGH"})
